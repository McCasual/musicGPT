// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  FREE
  PAID
}

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  email              String             @unique
  password           String             @map("password")
  displayName        String             @map("display_name")
  subscriptionStatus SubscriptionStatus @default(FREE) @map("subscription_status")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  refreshTokens  RefreshToken[]
  subscriptions Subscription[]
  prompts Prompt[]

  @@map("users")
}

model RefreshToken {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid @map("user_id")
  tokenHash         String        @unique @map("token_hash")
  expiresAt         DateTime      @map("expires_at")
  revokedAt         DateTime?     @map("revoked_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @db.Uuid @map("user_id")
  tier              SubscriptionStatus @default(FREE)
  gateway           String             @default("KHALTI")
  pidx              String?            @unique
  purchaseOrderId   String             @map("purchase_order_id")
  purchaseOrderName String             @map("purchase_order_name")
  amount            Int
  paymentUrl        String             @map("payment_url")
  gatewayStatus     String             @default("Initiated") @map("gateway_status")
  transactionId     String?            @map("transaction_id")
  active            Boolean            @default(false)
  expiresAt         DateTime?          @map("expires_at")
  canceledAt        DateTime?          @map("canceled_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, active])
  @@index([gatewayStatus])
  @@map("subscriptions")
}

enum PromptStatus {
  PENDING
  PROCESSING
  COMPLETED
}

model Prompt {
  id String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid @map("user_id")
  text String 
  status PromptStatus @default(PENDING)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, createdAt])
  @@map("prompts")
}
