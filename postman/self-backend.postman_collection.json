  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const contentType = pm.response.headers.get('Content-Type') || '';",
          "if (contentType.includes('application/json')) {",
          "  try {",
          "    const parsed = pm.response.json();",
          "    pm.environment.set('lastResponseJson', JSON.stringify(parsed));",
          "  } catch (error) {",
          "    console.warn('Response advertised JSON but parsing failed.', error);",
          "  }",
          "}"
        ]
      }
    }
