  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('registerEmail')) {",
                  "  pm.environment.set('registerEmail', `user${Date.now()}@example.com`);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data?.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data?.refreshToken) pm.environment.set('refreshToken', data.refreshToken);",
                  "if (data?.user?.id) pm.environment.set('userId', data.user.id);",
                  "if (data?.user?.email) pm.environment.set('loginEmail', data.user.email);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\",\n  \"displayName\": \"{{registerDisplayName}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a user and stores accessToken, refreshToken, and userId into environment variables."
          },
          "response": []
        },
